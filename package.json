    "test:all": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kjerneverk/riotplan": "file:../riotplan"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "@types/node": "latest",
