{
  "name": "@kjerneverk/riotplan-e2e",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "test": "vitest run --project local-http --project stdio",
    "test:http": "vitest run --project local-http",
    "test:stdio": "vitest run --project stdio",
    "test:protocol": "vitest run --project protocol",
